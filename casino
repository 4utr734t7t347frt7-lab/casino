    try:
        cash_out = float(cash_out)
    except:
        dealer("Invalid cashout.")
        return

    while True:
        time.sleep(0.7)
        multiplier += random.uniform(0.1, 0.8)
        print(f"Multiplier: x{multiplier:.2f}")

        if random.random() < (multiplier / 25):
            dealer("рџ’Ґ CRASHED!")
            balance -= bet
            save_balance()
            return

        if multiplier >= cash_out:
            winnings = int(bet * multiplier)
            dealer(f"Cashed out at x{multiplier:.2f}")
            balance += winnings
            save_balance()
            return

