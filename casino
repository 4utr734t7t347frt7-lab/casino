# ---------------- BLACKJACK ----------------
def blackjack(bet):
    global balance
    if bet > balance:
        dealer("Not enough coins.")
        return

    def draw():
        return random.randint(1, 11)

    player = [draw(), draw()]
    dealer_hand = [draw(), draw()]

    def total(h): return sum(h)

    print("Your hand:", player, "=", total(player))
    print("Dealer shows:", dealer_hand[0])

    while total(player) < 21:
        move = input("hit/stand: ").lower()
        if move == "hit":
            player.append(draw())
            print("You:", player, total(player))
        else:
            break

    if total(player) > 21:
        dealer("Bust.")
        balance -= bet
        save_balance()
        return

    while total(dealer_hand) < 17:
        dealer_hand.append(draw())

    print("Dealer:", dealer_hand, total(dealer_hand))

    if total(player) > 21 or total(dealer_hand) > total(player):
        dealer("You lose.")
        balance -= bet
    elif total(player) > total(dealer_hand):
        dealer("You win.")
        balance += bet
    else:
        dealer("Draw.")

    save_balance()

